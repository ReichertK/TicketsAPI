# ─────────────────────────────────────────────────────────────
# Cediac — Sistema de Tickets
# Variables de entorno del frontend (Vite)
# ─────────────────────────────────────────────────────────────
# Copiar este archivo como .env y completar los valores.
#
# IMPORTANTE: Todas las variables deben tener el prefijo VITE_
# para que Vite las exponga al código del navegador.
# ─────────────────────────────────────────────────────────────

# URL base de la API backend (incluye /api/v1).
# En desarrollo local con proxy de Vite, usar ruta relativa.
# En producción, usar la URL completa del servidor.
#   Desarrollo : /api/v1
#   Producción : https://tu-servidor.com/api/v1
VITE_API_URL=/api/v1

# URL del hub de SignalR para notificaciones en tiempo real.
# En desarrollo local con proxy de Vite, usar ruta relativa.
# En producción, usar la URL completa del servidor.
#   Desarrollo : /hubs/tickets
#   Producción : https://tu-servidor.com/hubs/tickets
VITE_SIGNALR_HUB_URL=/hubs/tickets
